{
  "name": "based-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Based language monorepo",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
