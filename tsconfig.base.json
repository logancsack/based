{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@based/lang-core": [
        "packages/lang-core/src/index.ts"
      ],
      "@based/stdlib": [
        "packages/stdlib/src/index.ts"
      ],
      "@based/server-kit": [
        "packages/server-kit/src/index.ts"
      ],
      "@based/web-ui": [
        "packages/web-ui/src/index.ts"
      ]
    },
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist"
  }
}
